  local found=0
  for period in daily weekly monthly; do
    local dir="/etc/periodic/$period"
    [[ -d "$dir" ]] || continue
    for f in "$dir"/*; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f")
      if [[ ! "$name" =~ ^[0-9]{3}\. ]]; then
        warn "Non-standard periodic script: $f"
        found=$((found + 1))
      else
        info "Periodic/$period: $name"
      fi
    done
  done
  if [[ "$found" -eq 0 ]]; then
