# ─── Supply chain checks ───

check_trusted_certs() {
  header "Trusted Root Certificates"

  local found=0

  # Known HTTPS interception proxy CA names (installed by developer MITM tools)
  local PROXY_CA_PATTERNS=("mitmproxy" "Charles Proxy" "PortSwigger" "Proxyman" "Fiddler" "MITM" "Burp")

  # User-level trust overrides — no root required
  # mitmproxy, Charles, Burp Suite, and Proxyman install their CA here
  local user_trust
  user_trust=$(security dump-trust-settings 2>/dev/null || true)

  if [[ -n "$user_trust" && "$user_trust" != *"No Trust Settings"* ]]; then
    while IFS= read -r line; do
      [[ "$line" =~ ^Cert\ [0-9]+:\ (.*) ]] || continue
      local cert_name="${BASH_REMATCH[1]}"
      [[ -z "$cert_name" ]] && continue

      local is_proxy=false
      for pat in "${PROXY_CA_PATTERNS[@]}"; do
        if [[ "$cert_name" == *"$pat"* ]]; then
          is_proxy=true
          break
        fi
      done

      if $is_proxy; then
        warn "HTTPS interception proxy CA trusted: $cert_name — all TLS traffic can be decrypted"
      else
        warn "Custom trusted certificate: $cert_name — verify this is expected"
      fi
      found=$((found + 1))
    done <<< "$user_trust"
  fi

  # Admin-level trust settings — MDM and enterprise tools install here
  local admin_trust
  admin_trust=$(security dump-trust-settings -d 2>/dev/null || true)
  if [[ -n "$admin_trust" && "$admin_trust" != *"No Trust Settings"* ]]; then
    while IFS= read -r line; do
      [[ "$line" =~ ^Cert\ [0-9]+:\ (.*) ]] || continue
      local cert_name="${BASH_REMATCH[1]}"
      [[ -z "$cert_name" ]] && continue
      warn "Admin-trusted certificate (system-wide MITM risk): $cert_name"
      found=$((found + 1))
    done <<< "$admin_trust"
  fi

  if [[ "$found" -eq 0 ]]; then
    ok "No custom trusted root certificates"
  fi
}

# Check a directory for recently installed items and report any installed within $age days.
# Usage: _check_recent_installs singular plural info_label dir [find_args...]
_check_recent_installs() {
  local singular="$1" plural="$2" info_label="$3" dir="$4"
  shift 4
  [[ -d "$dir" ]] || return 0
  local count now_epoch
  count=$(find "$dir" -maxdepth 1 "$@" 2>/dev/null | wc -l | tr -d ' ')
  info "${info_label}: $count"
  now_epoch=$(date +%s)
  local recent=0
  while IFS= read -r item; do
    [[ -z "$item" ]] && continue
    local mod_epoch age_days
    mod_epoch=$(stat -f '%m' "$item" 2>/dev/null || echo 0)
    age_days=$(( (now_epoch - mod_epoch) / 86400 ))
    if [[ "$age_days" -lt 7 ]]; then
      warn "${singular} installed <7 days ago: $(basename "$item")"
      recent=$((recent + 1))
    fi
  done < <(find "$dir" -maxdepth 1 "$@" 2>/dev/null)
  if [[ "$recent" -eq 0 ]]; then ok "No recently installed ${plural}"; fi
}

check_supply_chain() {
  header "Supply Chain"

  # VS Code extensions
  local vscode_dir="$HOME/.vscode/extensions"
  _check_recent_installs "VS Code extension" "VS Code extensions" "VS Code extensions" \
    "$vscode_dir" -mindepth 1 -type d

  # Cursor extensions (~/.cursor/extensions — same format as VS Code)
  local cursor_dir="$HOME/.cursor/extensions"
  _check_recent_installs "Cursor extension" "Cursor extensions" "Cursor extensions" \
    "$cursor_dir" -mindepth 1 -type d

  # npm globals
