  local gopath_bin=""
  if command -v go &>/dev/null; then
    gopath_bin="$(go env GOPATH 2>/dev/null)/bin"
  fi
  if [[ -n "$gopath_bin" ]]; then
    _check_recent_installs "Go binary" "Go binaries" "Go binaries (GOPATH/bin)" \
      "$gopath_bin" -type f -perm +111
  fi

  # uv/pipx user tools (~/.local/bin)
  local local_bin="$HOME/.local/bin"
  _check_recent_installs "local binary" "local binaries" "User local binaries (~/.local/bin)" \
    "$local_bin" -type f -perm +111
}

check_ai_agent_hooks() {
  header "AI Agent Configuration"

  local found=0

  # Claude Code global settings — hooks can run arbitrary shell commands
  local claude_settings="$HOME/.claude/settings.json"
  if [[ -f "$claude_settings" ]]; then
    if grep -q '"hooks"' "$claude_settings" 2>/dev/null; then
      # Extract "command" values from the hooks section
      local hook_cmds
      hook_cmds=$(grep '"command"' "$claude_settings" 2>/dev/null \
        | sed 's/.*"command"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
        | grep -v '^{' || true)
      local hook_count=0
      while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        hook_count=$((hook_count + 1))
        # Suspicious: outbound network, shell eval, or obfuscation
        if echo "$cmd" | grep -qE 'curl|wget|nc |ncat|socat|/dev/tcp|bash -c|sh -c|eval|base64 -d|python.*-c|ruby.*-e|perl.*-e'; then
          fail "Suspicious Claude Code hook command: $cmd"
          found=$((found + 1))
        else
          info "Claude Code hook: $cmd"
        fi
      done <<< "$hook_cmds"
      [[ "$hook_count" -gt 0 ]] || info "Claude Code hooks section present but no commands found"
    else
      ok "No hooks in ~/.claude/settings.json"
    fi
  fi

  # Claude Code project-level settings in common workspace locations
  # A malicious repo can ship .claude/settings.json with hooks that run on every tool call
  local ws_dirs=("$HOME/workspace" "$HOME/projects" "$HOME/code" "$HOME/src")
  local proj_hook_count=0
  for ws in "${ws_dirs[@]}"; do
    [[ -d "$ws" ]] || continue
    while IFS= read -r proj_settings; do
      [[ -f "$proj_settings" ]] || continue
      if grep -q '"hooks"' "$proj_settings" 2>/dev/null; then
        local rel_path="${proj_settings#"$HOME/"}"
        warn "Project-level Claude Code hooks: ~/$rel_path — verify before running claude in this repo"
        proj_hook_count=$((proj_hook_count + 1))
        found=$((found + 1))
      fi
    done < <(find "$ws" -maxdepth 3 -name "settings.json" -path "*/.claude/*" 2>/dev/null)
  done
  [[ "$proj_hook_count" -gt 0 ]] || info "No project-level Claude Code hooks found in workspace dirs"

  # Cursor Rules — can contain prompt injection to redirect AI actions
  local cursor_rules_dir="$HOME/.cursor/rules"
  if [[ -d "$cursor_rules_dir" ]]; then
    local rule_count
    rule_count=$(find "$cursor_rules_dir" -type f 2>/dev/null | wc -l | tr -d ' ')
    info "Cursor rules: $rule_count file(s) in ~/.cursor/rules/"
    while IFS= read -r rule_file; do
      # Classic prompt injection patterns targeting AI models
      if grep -qiE 'ignore (previous|above|prior|all) (instructions?|rules?)|disregard|override.*instructions?|new instruction' "$rule_file" 2>/dev/null; then
        warn "Potential prompt injection in Cursor rule: $(basename "$rule_file")"
        found=$((found + 1))
      fi
    done < <(find "$cursor_rules_dir" -type f 2>/dev/null)
  fi

  # GitHub Copilot repository instructions — injected into every Copilot context
  local copilot_files=(
    "$HOME/.github/copilot-instructions.md"
    ".github/copilot-instructions.md"
  )
  for cf in "${copilot_files[@]}"; do
    if [[ -f "$cf" ]]; then
      info "GitHub Copilot instructions present: $cf"
      if grep -qiE 'ignore (previous|above|prior)|disregard|exfiltrate|send.*to.*http' "$cf" 2>/dev/null; then
        warn "Potential prompt injection in Copilot instructions: $cf"
        found=$((found + 1))
      fi
    fi
  done

  if [[ "$found" -eq 0 ]]; then
    ok "No suspicious AI agent configurations found"
  fi
}

check_quarantine_events() {
  header "Quarantine Events"

  local db="$HOME/Library/Preferences/com.apple.LaunchServices.QuarantineEventsV2"
  if [[ ! -f "$db" ]]; then
    info "Quarantine database not found"
    return
  fi

  if ! command -v sqlite3 &>/dev/null; then
    info "sqlite3 not available — skipping"
    return
  fi

  # Mac absolute time epoch starts 2001-01-01, which is 978307200 Unix seconds later
  local mac_epoch_offset=978307200
  local lookback_days=14
  local cutoff_mac
  cutoff_mac=$(( $(date +%s) - mac_epoch_offset - (lookback_days * 86400) ))

  # Downloads via CLI/programmatic agents bypass browser quarantine security prompts.
  # Excludes Apple system processes (Gatekeeper, App Store).
  local cli_downloads
  cli_downloads=$(sqlite3 -readonly "$db" \
    "SELECT LSQuarantineAgentName, LSQuarantineDataURLString,
            datetime(LSQuarantineTimeStamp + $mac_epoch_offset, 'unixepoch', 'localtime')
     FROM LSQuarantineEvent
     WHERE LSQuarantineTimeStamp > $cutoff_mac
       AND (LSQuarantineAgentBundleIdentifier IS NULL
         OR LSQuarantineAgentBundleIdentifier NOT LIKE 'com.apple.%')
       AND (LSQuarantineAgentName LIKE 'curl%'
         OR LSQuarantineAgentName LIKE 'wget%'
         OR LSQuarantineAgentName LIKE 'python%'
         OR LSQuarantineAgentName LIKE 'ruby%'
         OR LSQuarantineAgentName LIKE 'perl%'
         OR LSQuarantineAgentName LIKE 'bash%'
         OR LSQuarantineAgentName = 'sh'
         OR LSQuarantineAgentName = 'zsh'
         OR LSQuarantineAgentName = 'osascript'
         OR LSQuarantineAgentName = 'Terminal')
     ORDER BY LSQuarantineTimeStamp DESC
     LIMIT 30;" 2>/dev/null || true)

  local total_recent
  total_recent=$(sqlite3 -readonly "$db" \
    "SELECT COUNT(*) FROM LSQuarantineEvent WHERE LSQuarantineTimeStamp > $cutoff_mac;" \
    2>/dev/null || echo "0")
  total_recent="${total_recent//[^0-9]/}"

  local found=0
  if [[ -n "$cli_downloads" ]]; then
    warn "Programmatic downloads in the last ${lookback_days} days — verify each was intentional:"
    while IFS='|' read -r agent url timestamp; do
      [[ -z "$url" ]] && continue
      echo -e "      ${DIM}[${timestamp}] ${agent}: ${url}${NC}"
      found=$((found + 1))
    done <<< "$cli_downloads"
  fi

  if [[ "$found" -eq 0 ]]; then
    ok "No CLI-sourced downloads in the last ${lookback_days} days"
    [[ "${total_recent:-0}" -gt 0 ]] && info "Recent downloads (browser/App Store): $total_recent"
  else
    info "Total recent downloads (all sources): $total_recent"
  fi
}

# ─── Configuration abuse checks ───

check_ssh_config() {
  header "SSH Config"

  local ssh_config="$HOME/.ssh/config"
  if [[ ! -f "$ssh_config" ]]; then
    ok "No SSH config file"
    return
  fi

  local issues=false

  # ProxyCommand (CVE-2025-61984 vector)
  local proxy_cmds
  proxy_cmds=$(grep -in 'ProxyCommand' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$proxy_cmds" ]]; then
    warn "SSH ProxyCommand found (potential CVE-2025-61984 vector):"
    echo "$proxy_cmds" | while read -r line; do echo "      $line"; done
    issues=true
  fi

  # SendEnv / SetEnv (data exfil vector)
  local env_directives
  env_directives=$(grep -in 'SendEnv\|SetEnv' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$env_directives" ]]; then
    warn "SSH environment forwarding configured:"
    echo "$env_directives" | while read -r line; do echo "      $line"; done
    issues=true
  fi

  # Forwarding rules
  local fwd_rules
  fwd_rules=$(grep -in 'LocalForward\|RemoteForward\|DynamicForward' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$fwd_rules" ]]; then
    info "SSH port forwarding rules:"
    echo "$fwd_rules" | while read -r line; do echo "      $line"; done
  fi

  # StrictHostKeyChecking no — disables MITM protection; C2 frameworks set this to avoid
  # interactive prompts when connecting to newly provisioned infrastructure
  local strict_check
  strict_check=$(grep -inE 'StrictHostKeyChecking[[:space:]]+no' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$strict_check" ]]; then
    warn "SSH StrictHostKeyChecking disabled — MITM attacks go undetected:"
    echo "$strict_check" | while read -r line; do echo "      $line"; done
    issues=true
  fi

  # UserKnownHostsFile /dev/null — silently discards host keys so every connection
  # appears "new"; paired with StrictHostKeyChecking no this is a classic C2 config
  local null_hosts
  null_hosts=$(grep -in 'UserKnownHostsFile[[:space:]].*\/dev\/null' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$null_hosts" ]]; then
    warn "SSH UserKnownHostsFile set to /dev/null — host keys never persisted (MITM risk):"
    echo "$null_hosts" | while read -r line; do echo "      $line"; done
    issues=true
  fi

  # ControlPath in /tmp — ControlMaster session multiplexing with a world-writable
  # socket path enables session hijacking by any local process
  local control_path
  control_path=$(grep -in 'ControlPath[[:space:]].*\/tmp\/' "$ssh_config" 2>/dev/null || true)
  if [[ -n "$control_path" ]]; then
    warn "SSH ControlPath in /tmp — session socket in world-writable dir (hijacking risk):"
    echo "$control_path" | while read -r line; do echo "      $line"; done
    issues=true
  fi

  if ! $issues; then
    ok "SSH config clean — no ProxyCommand, env forwarding, or MITM-enabling options"
  fi
}

check_git_hooks() {
  header "Git Hooks"

  # Global hooks path
  local global_hooks
  global_hooks=$(git config --global core.hooksPath 2>/dev/null || true)
  if [[ -n "$global_hooks" ]]; then
    warn "Global git hooks path: $global_hooks"
    if [[ -d "$global_hooks" ]]; then
      for hook in "$global_hooks"/*; do
        [[ -x "$hook" ]] || continue
        info "  Hook: $(basename "$hook")"
      done
    fi
  else
    ok "No global git hooks path configured"
  fi

  # Scan workspace repos for active hooks
  local hook_count=0
  if [[ -d "$HOME/workspace" ]]; then
    while IFS= read -r git_dir; do
      local hooks_dir="$git_dir/hooks"
      [[ -d "$hooks_dir" ]] || continue
      for hook in "$hooks_dir"/*; do
        [[ -x "$hook" ]] || continue
        local name
        name=$(basename "$hook")
        [[ "$name" == *.sample ]] && continue
        info "Workspace hook: ${hooks_dir#"$HOME"/} -> $name"
        hook_count=$((hook_count + 1))
      done
    done < <(find "$HOME/workspace" -maxdepth 4 -name ".git" -type d 2>/dev/null)
  fi

  if [[ "$hook_count" -eq 0 ]]; then
    ok "No active git hooks in workspace repos"
  fi
}

check_path_security() {
  header "PATH Security"

  local issues=0
  IFS=':' read -ra path_dirs <<< "$PATH"

  for dir in "${path_dirs[@]}"; do
    if [[ -z "$dir" ]]; then
      fail "Empty PATH entry ('::') — current directory is in PATH"
      issues=$((issues + 1))
      continue
    fi

    if [[ ! -d "$dir" ]]; then
      # Skip known Apple/system phantom paths
      case "$dir" in
        /var/run/com.apple.security.cryptexd/*|/opt/pmk/*)
          continue ;;
      esac
      warn "PATH directory does not exist: $dir"
      issues=$((issues + 1))
      continue
    fi

    # Check world-writable
    local perms
    perms=$(stat -f '%Sp' "$dir" 2>/dev/null || true)
    if [[ -n "$perms" && "${perms: -1}" == "w" ]]; then
      warn "World-writable PATH directory: $dir ($perms)"
      issues=$((issues + 1))
    fi
  done

  if [[ "$issues" -eq 0 ]]; then
    ok "PATH directories look secure"
  fi
}

check_dns_proxy() {
  header "DNS & Proxy Settings"

  # DNS resolvers
  local dns_out
  dns_out=$(scutil --dns 2>/dev/null | grep 'nameserver\[' | sort -u || true)
  if [[ -n "$dns_out" ]]; then
    info "DNS resolvers:"
    echo "$dns_out" | while read -r line; do
      local ip
      ip=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' || true)
      [[ -z "$ip" ]] && continue
      case "$ip" in
        8.8.8.8|8.8.4.4|1.1.1.1|1.0.0.1|9.9.9.9|208.67.222.222|208.67.220.220)
          echo "      $ip (well-known public DNS)" ;;
        127.0.0.1)
          echo "      $ip (localhost — local resolver)" ;;
        10.*|172.1[6-9].*|172.2[0-9].*|172.3[0-1].*|192.168.*)
          echo "      $ip (private network)" ;;
        *)
          echo "      $ip (verify this resolver)" ;;
      esac
    done
  fi

  # System proxy settings
  local net_services
  net_services=$(networksetup -listallnetworkservices 2>/dev/null | tail -n +2 || true)
  local proxy_found=false
  while read -r service; do
    [[ -z "$service" ]] && continue
    local web_proxy
    web_proxy=$(networksetup -getwebproxy "$service" 2>/dev/null || true)
    if echo "$web_proxy" | grep -q "Enabled: Yes"; then
      local proxy_server proxy_port
      proxy_server=$(echo "$web_proxy" | grep "Server:" | awk '{print $2}')
      proxy_port=$(echo "$web_proxy" | grep "Port:" | awk '{print $2}')
      warn "Web proxy enabled on $service: $proxy_server:$proxy_port"
      proxy_found=true
    fi

    local socks_proxy
    socks_proxy=$(networksetup -getsocksfirewallproxy "$service" 2>/dev/null || true)
    if echo "$socks_proxy" | grep -q "Enabled: Yes"; then
      local socks_server socks_port
      socks_server=$(echo "$socks_proxy" | grep "Server:" | awk '{print $2}')
      socks_port=$(echo "$socks_proxy" | grep "Port:" | awk '{print $2}')
      warn "SOCKS proxy enabled on $service: $socks_server:$socks_port"
      proxy_found=true
    fi
  done <<< "$net_services"

  if ! $proxy_found; then
    ok "No system proxies enabled"
  fi
}

