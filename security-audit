      done <<< "$taps"
    fi
  fi

  # MCP servers
  local mcp_configs=(
    "$HOME/Library/Application Support/Claude/claude_desktop_config.json"
    "$HOME/.cursor/mcp.json"
  )
  for mcp_file in "${mcp_configs[@]}"; do
    if [[ -f "$mcp_file" ]]; then
      local server_count
      server_count=$(grep -c '"command"' "$mcp_file" 2>/dev/null || true)
      server_count=${server_count:-0}
      if [[ "$server_count" -gt 0 ]]; then
        warn "MCP config with $server_count server(s): $(basename "$(dirname "$mcp_file")")/$(basename "$mcp_file")"
        grep '"command"' "$mcp_file" 2>/dev/null | while read -r line; do
          echo "      $(echo "$line" | sed 's/^[[:space:]]*//')"
        done
      fi
    fi
  done

  # pip user packages
  if command -v pip3 &>/dev/null; then
    local pip_user
    pip_user=$(pip3 list --user 2>/dev/null | tail -n +3 || true)
    if [[ -n "$pip_user" ]]; then
      local pip_count
      pip_count=$(echo "$pip_user" | wc -l | tr -d ' ')
      info "pip user packages: $pip_count"
    fi
  fi

  # Rust/cargo installed binaries
  local cargo_bin="$HOME/.cargo/bin"
  _check_recent_installs "cargo binary" "cargo binaries" "Cargo binaries (~/.cargo/bin)" \
    "$cargo_bin" -type f -perm +111

