check_privileged_helpers() {
  header "Persistence: Privileged Helper Tools"

  local helper_dir="/Library/PrivilegedHelperTools"
  if [[ ! -d "$helper_dir" ]]; then
    ok "No PrivilegedHelperTools directory"
    return
  fi

  local unsigned=0
  local checked=0
  for helper in "$helper_dir"/*; do
    [[ -f "$helper" ]] || continue
    local name
    name=$(basename "$helper")
    local sig
    sig=$(codesign -dv "$helper" 2>&1 || true)
    if echo "$sig" | grep -q "code object is not signed\|invalid signature"; then
      fail "Unsigned privileged helper: $name"
      unsigned=$((unsigned + 1))
    else
      local team
      team=$(echo "$sig" | grep "TeamIdentifier=" | cut -d= -f2)
      info "Helper: $name (Team: ${team:-unknown})"
    fi
    checked=$((checked + 1))
  done
  if [[ "$checked" -gt 0 && "$unsigned" -eq 0 ]]; then
    ok "All privileged helpers are signed"
  fi
}

check_xprotect_status() {
  header "XProtect Status"

  local xprotect_path="/Library/Apple/System/Library/CoreServices/XProtect.bundle"
  if [[ ! -d "$xprotect_path" ]]; then
    xprotect_path="/System/Library/CoreServices/XProtect.bundle"
  fi

  if [[ -d "$xprotect_path" ]]; then
    local version
    version=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" \
      "$xprotect_path/Contents/Info.plist" 2>/dev/null || echo "unknown")
    info "XProtect version: $version"

    local meta_plist="$xprotect_path/Contents/Resources/XProtect.meta.plist"
    if [[ -f "$meta_plist" ]]; then
      local mod_epoch now_epoch age_days
      mod_epoch=$(stat -f '%m' "$meta_plist" 2>/dev/null || echo 0)
      now_epoch=$(date +%s)
      age_days=$(( (now_epoch - mod_epoch) / 86400 ))
      if [[ "$age_days" -gt 30 ]]; then
        warn "XProtect data is ${age_days} days old — may be outdated"
      else
        ok "XProtect data updated ${age_days} day(s) ago"
      fi
    fi
  else
    warn "XProtect bundle not found"
  fi
}

