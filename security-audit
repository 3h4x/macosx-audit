#!/usr/bin/env bash
set -euo pipefail

# macOS Security Audit Script
# Checks for persistence mechanisms, suspicious processes, network activity,
# shell injections, supply chain risks, and system hardening status.
#
# Requires: bash 4+ (for associative arrays), macOS builtins
# Usage: security-audit [--config=PATH] [--all] [--root] [--check=NAME] [--list] [--help]

# ─── Bash version check ───

if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "Error: bash 4+ required (you have ${BASH_VERSION})"
  echo "Install with: brew install bash"
  exit 1
fi

# ─── Colors & output helpers ───

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

WARNINGS=0
FINDINGS=()
IGNORE_PATTERNS=()

header() { echo -e "\n${CYAN}${BOLD}=== $1 ===${NC}"; }
ok() { echo -e "  ${GREEN}[OK]${NC} $1"; }
warn() { echo -e "  ${YELLOW}[!]${NC} $1"; WARNINGS=$((WARNINGS + 1)); FINDINGS+=("$1"); }
fail() { echo -e "  ${RED}[!!]${NC} $1"; WARNINGS=$((WARNINGS + 1)); FINDINGS+=("[CRITICAL] $1"); }
info() { echo -e "  ${DIM}[-]${NC} $1"; }

# ─── Check registry ───

CHECKS=(system_hardening sharing_services screensaver launch_agents cron_jobs mdm_profiles shell_profiles
  env_injection extensions auth_plugins ssh_access process_integrity
  process_paths network_listening network_established docker
  periodic_scripts folder_actions privileged_helpers login_items
  xprotect_status supply_chain trusted_certs ai_agent_hooks quarantine_events ssh_config git_hooks path_security
  dns_proxy suspicious_ports reverse_dns
  temp_executables sudoers browser_extensions hidden_files reverse_shells
  system_integrity launchctl_state dylib_injection dns_tunneling
  recently_modified process_spoofing promiscuous_interfaces deleted_running
  tcc_permissions btm_dump)

# ─── Configuration ───

declare -A CONFIG

parse_config() {
  local file="$1"
  local in_ignore=false
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^ignore:[[:space:]]*$ ]]; then
      in_ignore=true
      continue
    fi
    if $in_ignore; then
      if [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.*) ]]; then
        local pattern="${BASH_REMATCH[1]}"
        pattern="${pattern#\"}" pattern="${pattern%\"}"
        pattern="${pattern#\'}" pattern="${pattern%\'}"
        IGNORE_PATTERNS+=("$pattern")
        continue
      else
        in_ignore=false
      fi
    fi
    if [[ "$line" =~ ^([a-z_]+):[[:space:]]*(true|false) ]]; then
      CONFIG["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
    fi
  done < "$file"
}

check_enabled() {
  local name="$1"
  if [[ -n "${SINGLE_CHECK:-}" ]]; then
    [[ "$name" == "$SINGLE_CHECK" ]] && return 0 || return 1
  fi
  if $RUN_ALL; then return 0; fi
  if [[ "$name" == "tcc_permissions" || "$name" == "btm_dump" ]]; then
    if $RUN_ROOT; then return 0; fi
    [[ "${CONFIG[$name]:-false}" == "true" ]] && return 0 || return 1
  fi
  [[ "${CONFIG[$name]:-true}" == "true" ]] && return 0 || return 1
}

# ─── CLI arguments ───

CONFIG_FILE=""
RUN_ALL=false
RUN_ROOT=false
SINGLE_CHECK=""

show_help() {
  cat <<'HELP'
Usage: security-audit [OPTIONS]

Options:
  --config=PATH   Use specified config file (default: auto-detect)
  --all           Enable all checks (including root-requiring)
  --root          Enable checks that require elevated privileges
  --check=NAME    Run only the specified check
  --list          List all available checks and exit
  --help          Show this help and exit

Config search order:
  1. --config=PATH (if specified)
  2. ./config.yaml
  3. ~/.config/macosx-audit/config.yaml
  4. <script_dir>/config.yaml
  5. Built-in defaults (all non-root checks enabled)
HELP
  exit 0
}

list_checks() {
  echo -e "${BOLD}Available checks:${NC}"
  echo ""
  echo -e "  ${CYAN}Core checks (no special permissions):${NC}"
  for name in system_hardening sharing_services screensaver launch_agents cron_jobs mdm_profiles shell_profiles \
    env_injection extensions auth_plugins ssh_access process_integrity \
    process_paths network_listening network_established docker; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Persistence & integrity:${NC}"
  for name in periodic_scripts folder_actions privileged_helpers xprotect_status login_items; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Supply chain:${NC}"
  for name in supply_chain trusted_certs ai_agent_hooks quarantine_events; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Configuration abuse:${NC}"
  for name in ssh_config git_hooks path_security dns_proxy; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Network:${NC}"
  for name in suspicious_ports reverse_dns; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Deep checks (round 2):${NC}"
  for name in temp_executables sudoers browser_extensions hidden_files reverse_shells \
    system_integrity launchctl_state dylib_injection dns_tunneling \
    recently_modified process_spoofing promiscuous_interfaces deleted_running; do
    local status="on"
    [[ "${CONFIG[$name]:-true}" == "false" ]] && status="off"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  echo ""
  echo -e "  ${CYAN}Elevated privileges (disabled by default):${NC}"
  for name in tcc_permissions btm_dump; do
    local status="off"
    [[ "${CONFIG[$name]:-false}" == "true" ]] && status="on"
    echo -e "    ${name}  ${DIM}[${status}]${NC}"
  done
  exit 0
}

for arg in "$@"; do
  case "$arg" in
    --config=*) CONFIG_FILE="${arg#--config=}" ;;
    --all) RUN_ALL=true; RUN_ROOT=true ;;
    --root) RUN_ROOT=true ;;
    --check=*) SINGLE_CHECK="${arg#--check=}" ;;
    --list) ;;
    --help) show_help ;;
    *) echo "Unknown option: $arg"; show_help ;;
  esac
done

# Find and parse config file
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -n "$CONFIG_FILE" ]]; then
  if [[ -f "$CONFIG_FILE" ]]; then
    parse_config "$CONFIG_FILE"
  else
    echo "Config file not found: $CONFIG_FILE" >&2
    exit 1
  fi
elif [[ -f "./config.yaml" ]]; then
  parse_config "./config.yaml"
elif [[ -f "$HOME/.config/macosx-audit/config.yaml" ]]; then
  parse_config "$HOME/.config/macosx-audit/config.yaml"
elif [[ -f "$SCRIPT_DIR/config.yaml" ]]; then
  parse_config "$SCRIPT_DIR/config.yaml"
fi

# Handle --list after config is loaded
for arg in "$@"; do
  [[ "$arg" == "--list" ]] && list_checks
done

# ─── Constants ───

KNOWN_AGENTS=(
  "com.apple."
  "com.google."
  "com.malwarebytes."
  "com.docker."
  "at.obdev.littlesnitch"
  "com.rogueamoeba."
  "homebrew.mxcl."
  "us.zoom."
  "com.native-instruments."
  "com.microsoft."
  "com.adobe."
  "com.spotify."
  "org.mozilla."
  "com.1password."
  "com.brave."
  "SessionManagerPlugin"
)

APPLE_SYSTEM_PATHS=(
  "/System/"
  "/usr/libexec/"
  "/usr/sbin/"
  "/usr/bin/"
  "/Library/Apple/"
)

SUSPECT_PORTS=(4444 5555 1337 31337 6666 6667 9001 8443 4443 3333 7777 1234 12345)

# ─── Check functions ───

check_system_hardening() {
  header "System Hardening"

  if csrutil status 2>&1 | grep -q "enabled"; then
    ok "System Integrity Protection (SIP) enabled"
  else
    fail "SIP is DISABLED — malware can modify system files"
  fi

  if spctl --status 2>&1 | grep -q "enabled"; then
    ok "Gatekeeper enabled"
  else
    warn "Gatekeeper disabled — unsigned apps can run freely"
  fi

  if fdesetup status 2>&1 | grep -q "On"; then
    ok "FileVault disk encryption enabled"
  else
    warn "FileVault OFF — disk is not encrypted"
  fi

  if /usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | grep -q "enabled\|blocking"; then
    ok "macOS Firewall enabled"
  else
    warn "macOS Firewall disabled"
  fi

  # Software update checks — auto-check and critical security patch install
  local auto_check critical_install
  auto_check=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticCheckEnabled 2>/dev/null || echo "0")
  critical_install=$(defaults read /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall 2>/dev/null || echo "0")
  if [[ "$auto_check" != "1" ]]; then
    warn "Automatic update checks disabled — security patches may be missed"
  elif [[ "$critical_install" != "1" ]]; then
    warn "Critical security updates auto-install disabled — patches require manual action"
  else
    ok "Automatic security updates enabled"
  fi
}

check_sharing_services() {
  header "Sharing Services"

  # Automatic Login — no password required at boot (physical access = full compromise)
  local auto_login
  auto_login=$(defaults read /Library/Preferences/com.apple.loginwindow autoLoginUser 2>/dev/null || true)
  if [[ -n "$auto_login" ]]; then
    fail "Automatic login enabled for: $auto_login — system boots without password"
  else
    ok "Automatic login disabled"
  fi

  # Guest Account — anonymous local access
  local guest_enabled
  guest_enabled=$(defaults read /Library/Preferences/com.apple.loginwindow GuestEnabled 2>/dev/null || echo "0")
  if [[ "$guest_enabled" == "1" ]]; then
    warn "Guest account is enabled — anonymous local access possible"
  else
    ok "Guest account disabled"
  fi

  # Remote Login (SSH server)
  local ssh_status
  ssh_status=$(systemsetup -getremotelogin 2>/dev/null || true)
  if echo "$ssh_status" | grep -qi "remote login: on"; then
    warn "Remote Login (SSH server) is ON — ensure only authorized keys are accepted"
  elif echo "$ssh_status" | grep -qi "remote login: off"; then
    ok "Remote Login (SSH server) disabled"
  else
    # systemsetup requires admin on Sonoma+; fall back to port listener check
    if lsof -i TCP:22 -sTCP:LISTEN -nP 2>/dev/null | grep -q sshd; then
      warn "sshd listening on port 22 — Remote Login may be enabled"
    else
      ok "Remote Login (SSH server) appears disabled"
    fi
  fi

  # Screen Sharing / Remote Management (VNC on port 5900)
  if lsof -i TCP:5900 -sTCP:LISTEN -nP 2>/dev/null | grep -q .; then
    fail "Screen Sharing / VNC listening on port 5900 — remote visual access possible"
  else
    ok "Screen Sharing disabled"
  fi

  # Remote Management ARD control channel (UDP 3283)
  if lsof -i UDP:3283 -nP 2>/dev/null | grep -qi "ARD\|remote"; then
    warn "Remote Management (ARD) appears active on UDP port 3283"
  fi

  # File Sharing (SMB port 445 or AFP port 548)
  if lsof -i TCP:445 -sTCP:LISTEN -nP 2>/dev/null | grep -q . || \
     lsof -i TCP:548 -sTCP:LISTEN -nP 2>/dev/null | grep -q .; then
    warn "File Sharing is enabled (SMB/AFP listener detected)"
  else
    ok "File Sharing disabled"
  fi
}

check_screensaver() {
  header "Screensaver Security"

  # Check if screensaver requires password on wake (askForPassword = 1 is required)
  # On Ventura+, this key is stored in the per-host domain; fall back to global domain.
  # On Sequoia+ (macOS 15+), the key may be absent entirely — absence means the system
  # default applies (password required). Only explicit 0 means disabled.
  local ask_pw
  ask_pw=$(defaults -currentHost read com.apple.screensaver askForPassword 2>/dev/null || \
           defaults read com.apple.screensaver askForPassword 2>/dev/null || true)

  if [[ "$ask_pw" != "0" ]]; then
    ok "Screensaver requires password on wake"

    # Check grace period before password is required (0 = immediate)
    # Value may be stored as float ("5.0") — strip decimal for integer comparison
    local pw_delay
    pw_delay=$(defaults read com.apple.screensaver askForPasswordDelay 2>/dev/null || echo "0")
    pw_delay="${pw_delay%%.*}"
    if [[ "$pw_delay" -eq 0 ]]; then
      ok "Password required immediately (no grace period)"
    else
      warn "Screensaver password delay: ${pw_delay}s — system can be unlocked without password within this window"
    fi
  else
    fail "Screensaver does NOT require password — physical access bypasses screen lock"
  fi

  # Check idle time before screensaver activates (per-host setting takes precedence)
  # On macOS 15+, idleTime may be absent from com.apple.screensaver; fall back to
  # display sleep time from pmset (which drives lock on modern macOS).
  local idle_time
  idle_time=$(defaults -currentHost read com.apple.screensaver idleTime 2>/dev/null || \
              defaults read com.apple.screensaver idleTime 2>/dev/null || true)
  idle_time="${idle_time%%.*}"

  if [[ -z "$idle_time" ]]; then
    # Key absent — check display sleep time as fallback (macOS 15+ behavior)
    local display_sleep
    display_sleep=$(pmset -g 2>/dev/null | awk '/displaysleep/ {print $2}')
    if [[ -n "$display_sleep" && "$display_sleep" -gt 0 ]]; then
      if [[ "$display_sleep" -gt 5 ]]; then
        warn "Display sleep (lock trigger) set to ${display_sleep} minute(s) — consider reducing to ≤5 minutes"
      else
        ok "Screen locks after ${display_sleep} minute(s) of inactivity (display sleep)"
      fi
    else
      warn "Screensaver auto-start is disabled — screen never locks automatically"
    fi
  elif [[ "$idle_time" -eq 0 ]]; then
    warn "Screensaver auto-start is disabled — screen never locks automatically"
  else
    local idle_min
    idle_min=$(( idle_time / 60 ))
    if [[ "$idle_time" -gt 300 ]]; then
      warn "Screensaver activates after ${idle_min} minute(s) — consider reducing to ≤5 minutes"
    else
      ok "Screensaver activates after ${idle_min} minute(s)"
    fi
  fi
}

check_launch_agents() {
  header "Persistence: LaunchAgents & LaunchDaemons"

  _check_plist_dir() {
    local dir="$1"
    local label="$2"
    if [[ ! -d "$dir" ]]; then return; fi

    for plist in "$dir"/*.plist; do
      [[ -f "$plist" ]] || continue
      local name
      name=$(basename "$plist" .plist)
      local known=false

      for prefix in "${KNOWN_AGENTS[@]}"; do
        if [[ "$name" == "$prefix"* ]]; then
          known=true
          break
        fi
      done

      local program
      program=$(/usr/libexec/PlistBuddy -c "Print :ProgramArguments:0" "$plist" 2>/dev/null || \
                /usr/libexec/PlistBuddy -c "Print :Program" "$plist" 2>/dev/null || echo "unknown")

      if $known; then
        # Verify com.apple.* entries point to Apple system paths
        if [[ "$name" == com.apple.* && "$program" != "unknown" ]]; then
          local valid_path=false
          for sys_path in "${APPLE_SYSTEM_PATHS[@]}"; do
            if [[ "$program" == "$sys_path"* ]]; then
              valid_path=true
              break
            fi
          done
          if ! $valid_path; then
            warn "${label}: ${name} claims Apple but runs from non-system path: ${program}"
            echo -e "      ${DIM}File: ${plist}${NC}"
            echo -e "      ${DIM}Modified: $(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$plist")${NC}"
          else
            info "${label}: ${name} -> ${program}"
          fi
        else
          info "${label}: ${name} -> ${program}"
        fi
      else
        warn "${label} UNKNOWN: ${name} -> ${program}"
        echo -e "      ${DIM}File: ${plist}${NC}"
        echo -e "      ${DIM}Modified: $(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$plist")${NC}"
      fi
    done
  }

  _check_plist_dir "$HOME/Library/LaunchAgents" "User Agent"
  _check_plist_dir "/Library/LaunchAgents" "System Agent"
  _check_plist_dir "/Library/LaunchDaemons" "System Daemon"
}

check_cron_jobs() {
  header "Persistence: Cron & At Jobs"

  cron_out=$(crontab -l 2>&1)
  if [[ "$cron_out" == *"no crontab"* ]]; then
    ok "No user crontab"
  else
    warn "User crontab exists:"
    echo "$cron_out" | while read -r line; do echo "      $line"; done
  fi

  if [[ -f /etc/crontab ]]; then
    warn "/etc/crontab exists"
  else
    ok "No /etc/crontab"
  fi

  at_out=$(atq 2>&1)
  if [[ -z "$at_out" ]]; then
    ok "No at jobs"
  else
    warn "at jobs found:"
    echo "$at_out" | while read -r line; do echo "      $line"; done
  fi
}

check_mdm_profiles() {
  header "Persistence: Configuration Profiles"

  profiles_out=$(profiles list 2>&1)
  if echo "$profiles_out" | grep -q "no configuration profiles"; then
    ok "No MDM/configuration profiles installed"
  else
    warn "Configuration profiles found:"
    echo "$profiles_out" | while read -r line; do echo "      $line"; done
  fi
}

check_shell_profiles() {
  header "Shell Profile Integrity"

  local shell_files=(
    "$HOME/.zshrc"
    "$HOME/.zprofile"
    "$HOME/.zshenv"
    "$HOME/.zlogin"
    "$HOME/.bashrc"
    "$HOME/.bash_profile"
    "$HOME/.profile"
  )

  local suspicious_patterns=(
    'curl.*\|.*sh'
    'wget.*\|.*sh'
    'curl.*\|.*bash'
    "base64.*decode"
    'eval.*\$\(curl'
    'eval.*\$\(wget'
    "/dev/tcp/"
    "nc -e"
    "ncat.*-e"
    "mkfifo"
    "openssl.*s_client"
  )

  for f in "${shell_files[@]}"; do
    [[ -f "$f" ]] || continue
    local is_suspicious=false
    for pat in "${suspicious_patterns[@]}"; do
      if grep -qE "$pat" "$f" 2>/dev/null; then
        fail "Suspicious pattern in $f: $(grep -E "$pat" "$f" | head -1)"
        is_suspicious=true
      fi
    done
    if ! $is_suspicious; then
      info "$(basename "$f") — clean ($(wc -l < "$f" | tr -d ' ') lines)"
    fi
  done

  if [[ -d "$HOME/.zshrc.d" ]]; then
    for f in "$HOME/.zshrc.d"/*; do
      [[ -f "$f" ]] || continue
      for pat in "${suspicious_patterns[@]}"; do
        if grep -qE "$pat" "$f" 2>/dev/null; then
          fail "Suspicious pattern in $f: $(grep -E "$pat" "$f" | head -1)"
        fi
      done
    done
    info ".zshrc.d/ — $(find "$HOME/.zshrc.d" -maxdepth 1 -mindepth 1 2>/dev/null | wc -l | tr -d ' ') files checked"
  fi
}

check_env_injection() {
  header "Environment Injection"

  dyld_vars=$(env | grep -iE '^DYLD_INSERT|^DYLD_FORCE|^DYLD_PRINT' 2>/dev/null || true)
  if [[ -n "$dyld_vars" ]]; then
    fail "DYLD injection variables set:"
    echo "$dyld_vars" | while read -r line; do echo "      $line"; done
  else
    ok "No DYLD injection variables"
  fi

  proxy_vars=$(env | grep -iE '^http_proxy=|^https_proxy=|^all_proxy=|^socks_proxy=' 2>/dev/null || true)
  if [[ -n "$proxy_vars" ]]; then
    warn "Proxy variables set (verify these are intentional):"
    echo "$proxy_vars" | while read -r line; do echo "      $line"; done
  else
    ok "No proxy hijack variables"
  fi

  ld_vars=$(env | grep -iE '^LD_PRELOAD=' 2>/dev/null || true)
  if [[ -n "$ld_vars" ]]; then
    fail "LD_PRELOAD set: $ld_vars"
  else
    ok "No LD_PRELOAD"
  fi
}

check_extensions() {
  header "Kernel & System Extensions"

  kext_count=$(find /Library/Extensions -maxdepth 1 -name '*.kext' -type d 2>/dev/null | wc -l | tr -d ' ' || true)
  kext_count=${kext_count:-0}
  if [[ "$kext_count" -gt 0 ]]; then
    info "$kext_count kernel extension(s) in /Library/Extensions:"
    find /Library/Extensions -maxdepth 1 -name '*.kext' -type d 2>/dev/null | while read -r k; do echo "      $(basename "$k")"; done
  else
    ok "No third-party kernel extensions"
  fi

  sysext_out=$(systemextensionsctl list 2>&1)
  if echo "$sysext_out" | grep -q "0 extension"; then
    ok "No system extensions"
  else
    info "System extensions:"
    echo "$sysext_out" | grep -E "^\*|bundleID" | while read -r line; do echo "      $line"; done
  fi
}

check_auth_plugins() {
  header "Authorization Plugins"

  auth_plugins=$(find /Library/Security/SecurityAgentPlugins -maxdepth 1 -mindepth 1 -print0 2>/dev/null | xargs -0 -I{} basename {} | head -20)
  if [[ -z "$auth_plugins" ]]; then
    ok "No authorization plugins"
  else
    warn "Authorization plugins found:"
    echo "$auth_plugins" | while read -r line; do echo "      $line"; done
  fi
}

check_ssh_access() {
  header "SSH Access"

  if [[ -f "$HOME/.ssh/authorized_keys" ]]; then
    key_count=$(grep -c '^ssh-\|^ecdsa-\|^sk-' "$HOME/.ssh/authorized_keys" 2>/dev/null || true)
    key_count=${key_count:-0}
    if [[ "$key_count" -gt 0 ]]; then
      warn "$key_count SSH authorized key(s) — verify these are yours:"
      while read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        echo "      ${line: -60}"
      done < "$HOME/.ssh/authorized_keys"
    else
      ok "authorized_keys exists but empty"
    fi
  else
    ok "No authorized_keys file"
  fi
}

check_process_integrity() {
  header "Process Integrity"

  info "Checking for unsigned or suspicious processes..."
  local unsigned_count=0

  while IFS= read -r line; do
    local pid comm binary
    pid=$(echo "$line" | awk '{print $1}')
    comm=$(echo "$line" | awk '{$1=""; print $0}' | sed 's/^[[:space:]]*//')
    [[ -z "$comm" ]] && continue
    [[ "$comm" == "-" || "$comm" == "/kernel" ]] && continue
    # Extract binary path (first word of args)
    binary="${comm%% *}"
    [[ "$binary" != /* ]] && continue
    [[ -f "$binary" ]] || continue

    sig_check=$(codesign -dv "$binary" 2>&1 || true)
    if echo "$sig_check" | grep -q "code object is not signed\|invalid signature\|a sealed resource is missing"; then
      warn "Unsigned/invalid process: PID=$pid $comm"
      unsigned_count=$((unsigned_count + 1))
    fi
  done < <(ps -eo pid,args 2>/dev/null | tail -n +2)

  if [[ "$unsigned_count" -eq 0 ]]; then
    ok "All running processes have valid signatures"
  fi
}

check_process_paths() {
  header "Process Paths"

  info "Checking for processes outside standard locations..."
  local unusual_count=0

  while IFS= read -r line; do
    local pid comm binary
    pid=$(echo "$line" | awk '{print $1}')
    comm=$(echo "$line" | awk '{$1=""; print $0}' | sed 's/^[[:space:]]*//')
    [[ -z "$comm" ]] && continue
    # Extract binary path (first word of args)
    binary="${comm%% *}"

    # Skip known safe paths
    if echo "$binary" | grep -qE '^/(System|Library|Applications|usr|sbin|bin|opt/homebrew|private|cores)/'; then
      continue
    fi
    # Skip known user paths (use /\. to match dotfiles inside absolute paths)
    if echo "$binary" | grep -qE '/\.(nvm|vscode|cache|foundry|local/bin|cargo)/|/node_modules/|/Claude\.app/|/\.claude/|/\.npm/'; then
      continue
    fi
    # Skip processes without a path
    if [[ "$binary" != /* && "$binary" != .* ]]; then
      continue
    fi

    info "Non-standard path: PID=$pid $comm"
    unusual_count=$((unusual_count + 1))
  done < <(ps -eo pid,args 2>/dev/null | tail -n +2)

  if [[ "$unusual_count" -eq 0 ]]; then
    ok "All processes running from standard locations"
  fi
}

check_network_listening() {
  header "Network: Listening Ports"

  while IFS= read -r line; do
    local proc pid addr
    proc=$(echo "$line" | awk '{print $1}')
    pid=$(echo "$line" | awk '{print $2}')
    addr=$(echo "$line" | awk '{print $9}')
    info "LISTEN $addr ($proc, PID $pid)"
  done < <(lsof -i -nP 2>/dev/null | grep LISTEN)
}

_identify_ip() {
  local ip="$1"
  # Strip IPv6 brackets
  ip="${ip#\[}"
  ip="${ip%\]}"

  case "$ip" in
    # Cloudflare
    104.16.*|104.17.*|104.18.*|104.19.*|104.20.*|104.21.*|104.22.*|104.23.*|104.24.*|104.25.*|104.26.*|104.27.*) echo "Cloudflare" ;;
    172.64.*|172.65.*|172.66.*|172.67.*|172.68.*|172.69.*|172.70.*|172.71.*) echo "Cloudflare" ;;
    162.159.*) echo "Cloudflare" ;;
    2606:4700:*) echo "Cloudflare" ;;
    2607:6bc0::*) echo "Cloudflare" ;;
    # Google
    142.250.*|142.251.*|172.217.*|172.253.*|216.58.*|74.125.*|64.233.*) echo "Google" ;;
    2a00:1450:*) echo "Google" ;;
    # Akamai (must precede broad AWS 23.* range)
    23.2[0-9].*|23.3[0-9].*|23.4[0-9].*|23.5[0-9].*|23.6[0-9].*) echo "Akamai" ;;
    # Microsoft/GitHub (must precede broad AWS 13.* and 52.* ranges)
    20.*|40.*|52.*|13.10[4-7].*|140.82.1[1-2]*) echo "Microsoft" ;;
    # AWS
    3.*|13.*|15.*|16.*|18.*|23.*|34.*|35.*|43.*|44.*|46.*|47.*|50.*|51.*|54.*|99.*|100.2[0-7].*) echo "AWS" ;;
    # Telegram
    149.154.16[4-9].*|149.154.17[0-5].*) echo "Telegram" ;;
    # Apple
    17.*) echo "Apple" ;;
    2620:149:*) echo "Apple" ;;
    # Local link
    fe80:*) echo "local-link" ;;
    # Private
    10.*|192.168.*|172.1[6-9].*|172.2[0-9].*|172.3[0-1].*) echo "private" ;;
    127.*|::1) echo "localhost" ;;
    *) echo "" ;;
  esac
}

_identify_process() {
  local proc="$1"
  case "$proc" in
    rapportd)   echo "AirDrop/Handoff discovery" ;;
    identitys*) echo "Apple identity services" ;;
    sharingd)   echo "AirDrop/sharing daemon" ;;
    apsd)       echo "Apple Push Notification" ;;
    cloudd)     echo "iCloud sync" ;;
    nsurlsess*) echo "Apple URL session" ;;
    AMPDeviceD*) echo "Apple Media" ;;
    symptomsd)  echo "Apple network diagnostics" ;;
    mDNSRespon*) echo "Bonjour/mDNS" ;;
    CommCenter) echo "cellular/SIM services" ;;
    parsecd)    echo "Siri suggestions" ;;
    *)          echo "" ;;
  esac
}

_resolve_process_name() {
  # Resolve a PID to a more descriptive name from full args
  local pid="$1"
  local lsof_proc="$2"
  local args
  args=$(ps -p "$pid" -o args= 2>/dev/null || true)
  [[ -z "$args" ]] && echo "$lsof_proc" && return

  # Extract app name from .app bundle path
  if [[ "$args" == *".app/"* ]]; then
    local app_name
    app_name=$(echo "$args" | grep -oE '[^/]+\.app' | head -1 | sed 's/\.app$//')
    [[ -n "$app_name" ]] && echo "$app_name" && return
  fi

  # Known CLI tools
  local binary="${args%% *}"
  case "$binary" in
    claude|*/claude)     echo "Claude CLI" && return ;;
    node|*/node)
      # Check what node is actually running
      local script="${args#* }"
      case "$script" in
        *playwright*) echo "Playwright MCP" && return ;;
        *next-server*) echo "Next.js" && return ;;
        *webpack*) echo "Webpack" && return ;;
        *vite*) echo "Vite" && return ;;
        *tsx*|*ts-node*) echo "Node (TS)" && return ;;
        *) echo "Node" && return ;;
      esac
      ;;
  esac

  # Check the comm field for descriptive names (e.g. "next-server (v15.5.9)")
  local comm
  comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
  if [[ "$comm" == next-server* ]]; then echo "Next.js" && return; fi

  echo "$lsof_proc"
}

check_network_established() {
  header "Network: Established Connections"

  local do_rdns=false
  check_enabled reverse_dns && do_rdns=true

  declare -A conn_procs
  while IFS= read -r line; do
    local proc pid dest key
    proc=$(echo "$line" | awk '{print $1}')
    pid=$(echo "$line" | awk '{print $2}')
    dest=$(echo "$line" | awk '{print $9}' | sed 's/.*->//')
    key="${proc}|${dest%:*}"
    if [[ -z "${conn_procs[$key]:-}" ]]; then
      conn_procs[$key]=1
      local ip="${dest%:*}"
      local label
      label=$(_identify_ip "$ip")
      local proc_desc resolved_name
      proc_desc=$(_identify_process "$proc")
      resolved_name=$(_resolve_process_name "$pid" "$proc")

      # Build display string
      local display="${resolved_name} (PID ${pid})"
      [[ -n "$proc_desc" ]] && display="${resolved_name} (${proc_desc}, PID ${pid})"
      local target="${dest}"
      if $do_rdns && [[ -z "$label" ]]; then
        local hostname
        hostname=$(host -W 1 "${ip#\[}" 2>/dev/null | awk '/domain name pointer/{print $NF}' | head -1)
        [[ -n "$hostname" ]] && label="${hostname%.}"
      fi
      [[ -n "$label" ]] && target="${dest} [${label}]"

      info "${display} -> ${target}"
    fi
  done < <(lsof -i -nP 2>/dev/null | grep ESTABLISHED)
}

check_docker() {
