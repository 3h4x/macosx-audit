# ─── Deep checks (round 2) ───

check_temp_executables() {
  header "Temp Directory Executables"

  local found=0
  local temp_dirs=(/tmp /var/tmp /private/tmp)

  for dir in "${temp_dirs[@]}"; do
    [[ -d "$dir" ]] || continue

    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local name
      name=$(basename "$f")
      local mod_epoch now_epoch age_hours
      mod_epoch=$(stat -f '%m' "$f" 2>/dev/null || echo 0)
      now_epoch=$(date +%s)
      age_hours=$(( (now_epoch - mod_epoch) / 3600 ))

      if [[ "$name" == .* ]]; then
        fail "Hidden executable in temp dir: $f (${age_hours}h old)"
      elif [[ "$age_hours" -lt 24 ]]; then
        warn "Recent executable in temp dir (<24h): $f"
      else
        info "Executable in temp dir: $f (${age_hours}h old)"
      fi
      found=$((found + 1))
    done < <(find "$dir" -maxdepth 3 -type f \( -perm +111 -o -name "*.sh" -o -name "*.py" -o -name "*.rb" -o -name "*.pl" \) 2>/dev/null)
  done

  if [[ "$found" -eq 0 ]]; then
    ok "No executables or scripts in temp directories"
  fi
}

check_sudoers() {
  header "Sudoers & PAM"

  local issues=0

  # Check /etc/sudoers for NOPASSWD
  if [[ -r /etc/sudoers ]]; then
    local nopasswd
    nopasswd=$(grep -n 'NOPASSWD' /etc/sudoers 2>/dev/null | grep -v '^[[:space:]]*#' || true)
    if [[ -n "$nopasswd" ]]; then
      warn "NOPASSWD entries in /etc/sudoers:"
      echo "$nopasswd" | while read -r line; do echo "      $line"; done
      issues=$((issues + 1))
    fi
  else
    info "/etc/sudoers not readable (expected without root)"
  fi

  # Check sudoers.d
  if [[ -d /etc/sudoers.d ]]; then
    local custom_count=0
    for f in /etc/sudoers.d/*; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f")
      [[ "$name" == "README" ]] && continue
      warn "Custom sudoers file: /etc/sudoers.d/$name"
      if grep -q 'NOPASSWD' "$f" 2>/dev/null; then
        fail "NOPASSWD in custom sudoers: /etc/sudoers.d/$name"
      fi
      custom_count=$((custom_count + 1))
      issues=$((issues + 1))
    done
    if [[ "$custom_count" -eq 0 ]]; then
      ok "No custom sudoers.d files"
    fi
  fi

  # Check PAM sudo module
  local pam_sudo="/etc/pam.d/sudo"
  if [[ -f "$pam_sudo" ]]; then
    local unusual_pam
    unusual_pam=$(grep -v '^#' "$pam_sudo" 2>/dev/null | grep 'auth' | grep -v 'pam_smartcard\|pam_opendirectory\|pam_tid\|pam_permit\|sudo_local' || true)
    if [[ -n "$unusual_pam" ]]; then
      warn "Non-default PAM auth module in sudo:"
      echo "$unusual_pam" | while read -r line; do echo "      $line"; done
      issues=$((issues + 1))
    else
      ok "PAM sudo config is default"
    fi
  fi

  if [[ "$issues" -eq 0 ]]; then
    ok "Sudoers configuration looks clean"
  fi
}

_resolve_chromium_ext_name() {
  # Resolve a Chromium extension ID to its human-readable name
  local ext_dir="$1"
  local ver_dir manifest name msg_key msgs
  ver_dir=$(find "$ext_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort | tail -1)
  [[ -z "$ver_dir" ]] && echo "unknown" && return
  manifest="$ver_dir/manifest.json"
  [[ ! -f "$manifest" ]] && echo "unknown" && return

  name=$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$manifest" 2>/dev/null | head -1 | sed 's/"name"[[:space:]]*:[[:space:]]*"//;s/"$//')
  if [[ "$name" == __MSG_* ]]; then
    msg_key="${name#__MSG_}"
    msg_key="${msg_key%__}"
    for locale_dir in "$ver_dir/_locales/en" "$ver_dir/_locales/en_US" "$ver_dir/_locales/en_GB"; do
      msgs="$locale_dir/messages.json"
      [[ -f "$msgs" ]] || continue
      local resolved
      resolved=$(grep -A2 "\"$msg_key\"" "$msgs" 2>/dev/null | grep '"message"' | head -1 | sed 's/.*"message"[[:space:]]*:[[:space:]]*"//;s/".*//')
      if [[ -n "$resolved" ]]; then
        echo "$resolved"
        return
      fi
    done
    echo "$name"
  elif [[ -n "$name" ]]; then
    echo "$name"
  else
    echo "unknown"
  fi
}

check_browser_extensions() {
  header "Browser Extensions"

  local total=0
  local recent=0

  # Chrome extensions
  local chrome_dir="$HOME/Library/Application Support/Google/Chrome/Default/Extensions"
  if [[ -d "$chrome_dir" ]]; then
    local count
    count=$(find "$chrome_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    count=${count:-0}
    info "Chrome: $count extension(s)"
    total=$((total + count))
    while IFS= read -r ext; do
      [[ -d "$ext" ]] || continue
      local mod_epoch now_epoch age_days
      mod_epoch=$(stat -f '%m' "$ext" 2>/dev/null || echo 0)
      now_epoch=$(date +%s)
      age_days=$(( (now_epoch - mod_epoch) / 86400 ))
      if [[ "$age_days" -lt 7 ]]; then
        local ext_name
        ext_name=$(_resolve_chromium_ext_name "$ext")
        warn "Chrome extension installed/updated <7 days ago: ${ext_name} ($(basename "$ext"))"
        recent=$((recent + 1))
      fi
    done < <(find "$chrome_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)
  fi

  # Brave extensions
  local brave_dir="$HOME/Library/Application Support/BraveSoftware/Brave-Browser/Default/Extensions"
  if [[ -d "$brave_dir" ]]; then
    local count
    count=$(find "$brave_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    count=${count:-0}
    info "Brave: $count extension(s)"
    total=$((total + count))
    while IFS= read -r ext; do
      [[ -d "$ext" ]] || continue
      local mod_epoch now_epoch age_days
      mod_epoch=$(stat -f '%m' "$ext" 2>/dev/null || echo 0)
      now_epoch=$(date +%s)
      age_days=$(( (now_epoch - mod_epoch) / 86400 ))
      if [[ "$age_days" -lt 7 ]]; then
        local ext_name
        ext_name=$(_resolve_chromium_ext_name "$ext")
        warn "Brave extension installed/updated <7 days ago: ${ext_name} ($(basename "$ext"))"
        recent=$((recent + 1))
      fi
    done < <(find "$brave_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)
  fi

  # Firefox extensions
  local firefox_dir="$HOME/Library/Application Support/Firefox/Profiles"
  if [[ -d "$firefox_dir" ]]; then
    local fx_count=0
    while IFS= read -r profile; do
      local ext_dir="$profile/extensions"
      [[ -d "$ext_dir" ]] || continue
      local pcount
      pcount=$(find "$ext_dir" -maxdepth 1 -mindepth 1 2>/dev/null | wc -l | tr -d ' ')
      fx_count=$((fx_count + pcount))
    done < <(find "$firefox_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)
    if [[ "$fx_count" -gt 0 ]]; then
      info "Firefox: $fx_count extension(s)"
      total=$((total + fx_count))
    fi
  fi

  # Safari extensions
  local safari_dir="$HOME/Library/Safari/Extensions"
  if [[ -d "$safari_dir" ]]; then
    local count
    count=$(find "$safari_dir" -maxdepth 1 -mindepth 1 2>/dev/null | wc -l | tr -d ' ')
    count=${count:-0}
    if [[ "$count" -gt 0 ]]; then
      info "Safari: $count extension(s)"
      total=$((total + count))
    fi
  fi

  if [[ "$total" -eq 0 ]]; then
    ok "No browser extensions found"
  elif [[ "$recent" -eq 0 ]]; then
    ok "No recently installed browser extensions"
  fi
}

check_hidden_files() {
  header "Suspicious Hidden Files"

  local found=0
  local temp_dirs=(/tmp /var/tmp /private/tmp)

  # Dotfiles in temp dirs
  for dir in "${temp_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      warn "Hidden file in temp dir: $f"
      found=$((found + 1))
    done < <(find "$dir" -maxdepth 2 -name ".*" -type f 2>/dev/null | head -20)
  done

  # Extended attributes hiding data in temp (exclude normal macOS attrs)
  for dir in "${temp_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    local xattr_out
    xattr_out=$(xattr -lr "$dir" 2>/dev/null | grep -v 'com.apple.provenance\|com.apple.quarantine\|com.apple.metadata\|com.apple.lastuseddate\|com.apple.macl' | head -20 || true)
    if [[ -n "$xattr_out" ]]; then
      warn "Non-standard extended attributes on temp files in $dir:"
      echo "$xattr_out" | head -5 | while read -r line; do echo "      $line"; done
      found=$((found + 1))
    fi
  done

  # Hidden files in Application Support with unusual names
  local app_support="$HOME/Library/Application Support"
  if [[ -d "$app_support" ]]; then
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      info "Hidden file in Application Support: $f"
      found=$((found + 1))
    done < <(find "$app_support" -maxdepth 2 -name ".*" -not -name ".DS_Store" -not -name ".localized" -type f 2>/dev/null | head -20)
  fi

  if [[ "$found" -eq 0 ]]; then
    ok "No suspicious hidden files found"
  fi
}

check_reverse_shells() {
  header "Reverse Shell Detection"

  local found=0

  # True reverse shell signature: shell has stdin/stdout/stderr (FD 0/1/2) pointing to a network socket
  # Inherited sockets from parent processes use higher FDs and are not reverse shells
  local shells=("bash" "zsh" "sh" "dash")
  for shell in "${shells[@]}"; do
    # Get all shell PIDs
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      pid=$(echo "$pid" | tr -d ' ')
      # Check if FD 0, 1, or 2 is a network socket (IPv4/IPv6)
      local fd_check
      fd_check=$(lsof -p "$pid" -nP 2>/dev/null | awk '$4 ~ /^[012][urw]?$/ && $5 ~ /IPv[46]/' || true)
      if [[ -n "$fd_check" ]]; then
        local dest
        dest=$(echo "$fd_check" | head -1 | awk '{print $9}')
        fail "Shell ($shell) with stdin/stdout on network socket: PID=$pid -> $dest"
        found=$((found + 1))
      fi
    done < <(pgrep -x "$shell" 2>/dev/null || true)
  done

  # Check for nc/ncat/socat with established connections (exact process match via pgrep)
  for tool in nc ncat socat; do
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      pid=$(echo "$pid" | tr -d ' ')
      local conns
      conns=$(lsof -p "$pid" -i -nP 2>/dev/null | grep ESTABLISHED || true)
      if [[ -n "$conns" ]]; then
        local dest
        dest=$(echo "$conns" | head -1 | awk '{print $9}')
        fail "$tool with established connection: PID=$pid -> $dest"
        found=$((found + 1))
      fi
    done < <(pgrep -x "$tool" 2>/dev/null || true)
  done

  if [[ "$found" -eq 0 ]]; then
    ok "No reverse shell indicators detected"
  fi
}

check_system_integrity() {
  header "System Binary Integrity"

  local critical_bins=(
    /usr/bin/login
    /usr/bin/sudo
    /usr/bin/ssh
    /usr/sbin/sshd
    /usr/bin/su
    /usr/bin/env
    /usr/bin/passwd
  )

  local issues=0
  for bin in "${critical_bins[@]}"; do
    [[ -f "$bin" ]] || continue

    # Check if it's actually a binary (not a script replacing it)
    local filetype
    filetype=$(file -b "$bin" 2>/dev/null || echo "unknown")
    if echo "$filetype" | grep -qiE 'script|text|ascii'; then
      fail "Critical binary replaced by script: $bin ($filetype)"
      issues=$((issues + 1))
      continue
    fi

    # Verify code signature
    local sig
    sig=$(codesign -dv "$bin" 2>&1 || true)
    if echo "$sig" | grep -q "code object is not signed\|invalid signature\|a sealed resource is missing"; then
      fail "Invalid signature on critical binary: $bin"
      issues=$((issues + 1))
    fi
  done

  # Recently modified files in system bin dirs
  local recent_count=0
  for dir in /usr/bin /usr/sbin /usr/local/bin; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      warn "Recently modified system binary (<7 days): $f"
      recent_count=$((recent_count + 1))
    done < <(find "$dir" -type f -mtime -7 2>/dev/null)
  done

  if [[ "$issues" -eq 0 && "$recent_count" -eq 0 ]]; then
    ok "Critical system binaries intact"
  fi
}

check_launchctl_state() {
  header "Launchd Service State"

  local orphan_count=0

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local label
    label=$(echo "$line" | awk '{print $3}')
    [[ -z "$label" || "$label" == "-" ]] && continue
    # Skip Apple and system services
    [[ "$label" == com.apple.* || "$label" == application.* ]] && continue

    # Check if there's a plist on disk
    local found_plist=false
    for pdir in "$HOME/Library/LaunchAgents" "/Library/LaunchAgents" "/Library/LaunchDaemons" \
      "/System/Library/LaunchAgents" "/System/Library/LaunchDaemons"; do
      if [[ -f "$pdir/${label}.plist" ]]; then
        found_plist=true
        break
      fi
    done

    if ! $found_plist; then
      info "Running service without standard plist: $label"
      orphan_count=$((orphan_count + 1))
    fi
  done < <(launchctl list 2>/dev/null | tail -n +2)

  if [[ "$orphan_count" -eq 0 ]]; then
    ok "All running services have matching plist files"
  else
    info "$orphan_count service(s) without standard plist files (may be dynamically loaded)"
  fi
}

check_dylib_injection() {
  header "DYLD Injection (Extended)"

  local found=0

  # Check shell profiles for DYLD vars beyond DYLD_INSERT_LIBRARIES
  local shell_files=(
    "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.zshenv"
    "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"
  )
  local dyld_patterns=("DYLD_LIBRARY_PATH" "DYLD_FRAMEWORK_PATH"
    "DYLD_FALLBACK_LIBRARY_PATH" "DYLD_VERSIONED_LIBRARY_PATH")

  for f in "${shell_files[@]}"; do
    [[ -f "$f" ]] || continue
    for pat in "${dyld_patterns[@]}"; do
      if grep -q "$pat" "$f" 2>/dev/null; then
        warn "$pat set in $(basename "$f")"
        found=$((found + 1))
      fi
    done
  done

  # Check /etc/launchd.conf for DYLD vars (system-wide injection)
  if [[ -f /etc/launchd.conf ]]; then
    local dyld_conf
    dyld_conf=$(grep -i 'DYLD_' /etc/launchd.conf 2>/dev/null || true)
    if [[ -n "$dyld_conf" ]]; then
      fail "DYLD variables in /etc/launchd.conf (system-wide injection):"
      echo "$dyld_conf" | while read -r line; do echo "      $line"; done
      found=$((found + 1))
    fi
  fi

  # Look for .dylib files in non-standard locations
  local suspicious_dirs=(/tmp /var/tmp /private/tmp "$HOME/Downloads" "$HOME/Desktop")
  for dir in "${suspicious_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      warn "Suspicious .dylib in non-standard location: $f"
      found=$((found + 1))
    done < <(find "$dir" -maxdepth 3 -name "*.dylib" -type f 2>/dev/null)
  done

  if [[ "$found" -eq 0 ]]; then
    ok "No DYLD injection indicators"
  fi
}

check_dns_tunneling() {
  header "DNS Tunneling Indicators"

  local found=0

  # Check for processes making direct DNS requests to external resolvers
  local external_dns=("8.8.8.8" "8.8.4.4" "1.1.1.1" "1.0.0.1" "9.9.9.9")
  for dns_ip in "${external_dns[@]}"; do
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local proc pid
      proc=$(echo "$line" | awk '{print $1}')
      pid=$(echo "$line" | awk '{print $2}')
      # Skip mDNSResponder and known DNS tools
      [[ "$proc" == "mDNSRespo" || "$proc" == "mDNSResponder" || "$proc" == "systemstats" ]] && continue
      info "Process connecting to external DNS ${dns_ip}: ${proc} (PID ${pid})"
    done < <(lsof -i "UDP@${dns_ip}:53" -nP 2>/dev/null | grep -v "^COMMAND" || true)
  done

  # Check for DoH config in Chrome
  local chrome_prefs="$HOME/Library/Application Support/Google/Chrome/Default/Preferences"
  if [[ -f "$chrome_prefs" ]]; then
    if grep -q '"dns_over_https"' "$chrome_prefs" 2>/dev/null; then
      local doh_mode
      doh_mode=$(grep -o '"mode":"[^"]*"' "$chrome_prefs" 2>/dev/null | head -1 || true)
      info "Chrome DNS-over-HTTPS configured: $doh_mode"
    fi
  fi

  # Check for unusually high DNS query volume (last 5 minutes)
  # Count actual query STARTs (not all log lines — each lookup generates 4-8 lines)
  local dns_logs dns_query_count
  dns_logs=$(timeout 10 log show --predicate 'process == "mDNSResponder"' --last 5m --style compact 2>/dev/null || true)
  dns_query_count=$(echo "$dns_logs" | grep -c 'DNSServiceQueryRecord START' || true)

  if [[ "$dns_query_count" -gt 500 ]]; then
    warn "High DNS query volume in last 5 minutes: $dns_query_count queries (possible DNS tunneling)"
    found=$((found + 1))

    # Break down by process so the user can investigate
    info "DNS query breakdown by process (top 10):"
    echo "$dns_logs" \
      | grep -oE 'client pid: [0-9]+ \([^)]+\)' \
      | sed 's/client pid: [0-9]* (\(.*\))/\1/' \
      | sort | uniq -c | sort -rn | head -10 \
      | while read -r count proc; do
          info "  ${count} queries — ${proc}"
        done

    # Show unique name hashes to gauge query diversity (tunneling = many unique names)
    local unique_names
    unique_names=$(echo "$dns_logs" | grep -oE 'name hash: [0-9a-f]+' | sort -u | wc -l | tr -d ' ')
    info "Unique domains queried: ~${unique_names}"
    if [[ "$unique_names" -gt 200 ]]; then
      warn "Very high domain diversity (${unique_names} unique) — typical of DNS tunneling or heavy browsing"
    fi
  else
    info "DNS query volume in last 5 minutes: $dns_query_count queries"
  fi

  if [[ "$found" -eq 0 ]]; then
    ok "No DNS tunneling indicators"
  fi
}

check_recently_modified() {
  header "Recently Modified System Files"

  local found=0

  # System binaries modified in last 7 days
  for dir in /usr/bin /usr/sbin /usr/lib; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      warn "Recently modified (<7 days): $f"
      found=$((found + 1))
    done < <(find "$dir" -type f -mtime -7 2>/dev/null)
  done

  # /System modifications (should never happen with SIP, except asset updates)
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    # Apple auto-updates AssetsV2 (Siri models, translations) — not suspicious
    [[ "$f" == */AssetsV2/* ]] && continue
    fail "Recently modified in /System (<7 days): $f"
    found=$((found + 1))
  done < <(find /System -type f -mtime -7 2>/dev/null | head -10)

  # New plist files in /Library/Preferences
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    info "Recent plist in /Library/Preferences: $(basename "$f")"
    found=$((found + 1))
  done < <(find /Library/Preferences -name "*.plist" -type f -mtime -7 2>/dev/null | head -10)

  if [[ "$found" -eq 0 ]]; then
    ok "No recently modified system files"
  fi
}

check_process_spoofing() {
  header "Process Name Spoofing"

  local found=0

  # Compare ps comm (short name, can be changed) vs args (actual binary path)
  while IFS= read -r line; do
    local pid comm args binary
    pid=$(echo "$line" | awk '{print $1}')
    comm=$(echo "$line" | awk '{print $2}')
    args=$(echo "$line" | awk '{$1=""; $2=""; print $0}' | sed 's/^[[:space:]]*//')
    binary="${args%% *}"

    [[ -z "$comm" || -z "$binary" || "$binary" != /* ]] && continue

    # Flag: comm suggests Apple but binary is outside /System
    if [[ "$comm" == com.apple.* && "$binary" != /System/* && "$binary" != /usr/libexec/* && "$binary" != /usr/sbin/* ]]; then
      fail "Process name spoofing: comm=$comm but binary=$binary (PID $pid)"
      found=$((found + 1))
    fi
  done < <(ps -eo pid,comm,args 2>/dev/null | tail -n +2)

  if [[ "$found" -eq 0 ]]; then
    ok "No process name spoofing detected"
  fi
}

check_promiscuous_interfaces() {
  header "Promiscuous Network Interfaces"

  local found=false
  # Parse ifconfig output for active interfaces in promiscuous mode
  local current_iface=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^([a-z0-9]+):[[:space:]].*flags= ]]; then
      current_iface="${BASH_REMATCH[1]}"
    fi
    # Only flag active interfaces (status: active) in PROMISC mode
    if [[ "$line" == *"PROMISC"* && -n "$current_iface" ]]; then
      # Check if interface is active
      local iface_status
      iface_status=$(ifconfig "$current_iface" 2>/dev/null | grep "status:" || true)
      if [[ "$iface_status" == *"status: active"* ]]; then
        warn "Active interface in promiscuous mode: $current_iface (packet sniffing)"
        found=true
      fi
    fi
  done < <(ifconfig 2>/dev/null)

  if ! $found; then
    ok "No active interfaces in promiscuous mode"
  fi
}

check_deleted_running() {
  header "Processes Running from Deleted Files"

  local found=0

  # Check if process binaries still exist on disk
  # The rootkit pattern: execute a binary then delete it so forensics can't find it
  # Note: lsof +L1 is too noisy on macOS (dyld cache updates cause many false positives)
  while IFS= read -r line; do
    local pid binary
    pid=$(echo "$line" | awk '{print $1}')
    binary=$(echo "$line" | awk '{$1=""; print $0}' | sed 's/^[[:space:]]*//')
    binary="${binary%% *}"
    [[ -z "$binary" || "$binary" != /* ]] && continue
    # Skip Apple system paths (updates leave stale references, not suspicious)
    [[ "$binary" == /System/* || "$binary" == /usr/libexec/* || "$binary" == /usr/sbin/* || "$binary" == /usr/bin/* ]] && continue
    # Skip known app frameworks
    [[ "$binary" == /Applications/* || "$binary" == /Library/* ]] && continue

    if [[ ! -f "$binary" ]]; then
      local proc_name
      proc_name=$(ps -p "$pid" -o comm= 2>/dev/null || echo "unknown")
      warn "Process binary no longer on disk: $proc_name (PID $pid) -> $binary"
      found=$((found + 1))
    fi
  done < <(ps -eo pid,args 2>/dev/null | tail -n +2)

  if [[ "$found" -eq 0 ]]; then
    ok "No processes running from deleted binaries"
  fi
}

# ─── Elevated privilege checks ───

check_tcc_permissions() {
  header "TCC Permissions (requires Full Disk Access)"

  local tcc_db="/Library/Application Support/com.apple.TCC/TCC.db"
  if [[ ! -r "$tcc_db" ]]; then
    info "Cannot read TCC database — requires Full Disk Access or root"
    return
  fi

  local services=("kTCCServiceCamera" "kTCCServiceMicrophone" "kTCCServiceScreenCapture"
                   "kTCCServiceAccessibility" "kTCCServiceSystemPolicyAllFiles")
  local labels=("Camera" "Microphone" "Screen Recording" "Accessibility" "Full Disk Access")

  for i in "${!services[@]}"; do
    local svc="${services[$i]}"
    local label="${labels[$i]}"
    local grants
    grants=$(sqlite3 "$tcc_db" \
      "SELECT client FROM access WHERE service='$svc' AND auth_value=2;" 2>/dev/null || true)
    if [[ -n "$grants" ]]; then
      info "$label granted to:"
      echo "$grants" | while read -r client; do echo "      $client"; done
    fi
  done
}

check_btm_dump() {
  header "Background Task Management (requires root)"

  local btm_output
  btm_output=$(sfltool dumpbtm 2>/dev/null || true)
  if [[ -z "$btm_output" ]]; then
    info "Cannot dump BTM — requires root privileges"
    return
  fi

  local unsigned
  unsigned=$(echo "$btm_output" | grep -B2 "Developer.*unknown\|not signed" 2>/dev/null || true)
  if [[ -n "$unsigned" ]]; then
    warn "BTM entries with unknown developer or unsigned:"
    echo "$unsigned" | while read -r line; do echo "      $line"; done
  else
    ok "All BTM entries from known developers"
  fi

  local item_count
  item_count=$(echo "$btm_output" | grep -c "Item:" 2>/dev/null || true)
  item_count=${item_count:-0}
  info "BTM total items: $item_count"
}

# ─── Main ───

echo -e "${BOLD}macOS Security Audit${NC} — $(date '+%Y-%m-%d %H:%M:%S')"
echo -e "${DIM}Host: $(hostname) | User: $(whoami) | macOS $(sw_vers -productVersion)${NC}"

if [[ -n "${SINGLE_CHECK:-}" ]]; then
  valid=false
  for name in "${CHECKS[@]}"; do
    if [[ "$name" == "$SINGLE_CHECK" ]]; then
      valid=true
      break
    fi
  done
  if ! $valid; then
    echo -e "${RED}Unknown check: $SINGLE_CHECK${NC}"
    echo "Run with --list to see available checks"
    exit 1
  fi
  "check_${SINGLE_CHECK}"
else
  for name in "${CHECKS[@]}"; do
    check_enabled "$name" && "check_${name}" || true
  done
fi

# ─── Summary ───

echo ""
echo -e "${BOLD}─── Summary ───${NC}"
echo ""

# Filter findings against ignore patterns
VISIBLE_FINDINGS=()
IGNORED_COUNT=0
for f in "${FINDINGS[@]}"; do
  _ignored=false
  for pattern in "${IGNORE_PATTERNS[@]}"; do
    if [[ "$f" == *"$pattern"* ]]; then
      _ignored=true
      break
    fi
  done
  if $_ignored; then
    IGNORED_COUNT=$(( IGNORED_COUNT + 1 ))
  else
    VISIBLE_FINDINGS+=("$f")
  fi
done

if [[ "${#VISIBLE_FINDINGS[@]}" -eq 0 ]]; then
  echo -e "${GREEN}${BOLD}No issues found.${NC} System looks clean."
  if [[ "$IGNORED_COUNT" -gt 0 ]]; then
    echo -e "${DIM}(${IGNORED_COUNT} finding(s) suppressed by ignore list)${NC}"
  fi
else
  echo -e "${YELLOW}${BOLD}${#VISIBLE_FINDINGS[@]} finding(s):${NC}"
  for f in "${VISIBLE_FINDINGS[@]}"; do
    echo -e "  ${YELLOW}-${NC} $f"
  done
  if [[ "$IGNORED_COUNT" -gt 0 ]]; then
    echo -e "${DIM}  (${IGNORED_COUNT} additional finding(s) suppressed by ignore list)${NC}"
  fi
fi

echo ""
echo -e "${DIM}Scan completed at $(date '+%H:%M:%S')${NC}"
